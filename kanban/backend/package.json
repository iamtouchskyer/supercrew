{
  "name": "@supercrew/backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:vitest": "vitest run",
    "verify": "npm run typecheck:node && npm run test:vitest"
  },
  "dependencies": {
    "@types/node": "^25.3.3",
    "@vercel/kv": "^3.0.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.3",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "chokidar": "^4.0.3",
    "vitest": "^3.2.4"
  }
}
