{
  "name": "@supercrew/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && bun run src/index.ts",
    "dev:frontend": "cd frontend/packages/local-web && pnpm dev",
    "build:api": "esbuild backend/api-entry.ts --bundle --platform=node --format=esm --outfile=api/index.js",
    "verify": "cd backend && npm run verify",
    "test": "cd backend && npm run test:vitest",
    "typecheck": "cd backend && npm run typecheck:node"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.3"
  }
}
