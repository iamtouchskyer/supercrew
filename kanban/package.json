{
  "name": "@supercrew/app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && bun run src/index.ts",
    "dev:frontend": "cd frontend/packages/local-web && pnpm dev"
  },
  "dependencies": {
    "@types/node": "^25.3.3",
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
